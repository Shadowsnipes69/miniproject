        if (!empty($query)) {
            try {
                $sql = "SELECT * FROM student 
                        WHERE id LIKE :query 
                           OR voornaam LIKE :query 
                           OR achternaam LIKE :query 
                           OR geslacht LIKE :query 
                           OR studierichting LIKE :query 
                           OR klas LIKE :query 
                           OR email LIKE :query 
                           OR telefoon LIKE :query 
                           OR woonplaats LIKE :query 
                           OR land LIKE :query 
                           OR CAST(gemiddelde_cijfer AS CHAR) LIKE :query 
                        ORDER BY voornaam, achternaam";
                
                $student = $conn->prepare($sql);
                $student->execute([':query' => "%$query%"]);
                $results = $student->fetchAll();
                
                // Totaal aantal studenten ophalen
                $total = $conn->query("SELECT COUNT(*) FROM student")->fetchColumn();
                $total_students = $total;
