<?php
// Database connectie (pas aan naar jouw instellingen)
$host = "localhost";
$user = "root";
$pass = "";
$db = "student";
$conn = new mysqli($host, $user, $pass, $db);

if ($conn->connect_error) {
    die("Connectie mislukt: " . $conn->connect_error);
}

// Maak de tabel aan als deze niet bestaat
$table_sql = "CREATE TABLE IF NOT EXISTS student (
    id INT AUTO_INCREMENT PRIMARY KEY,
    voornaam VARCHAR(255) NOT NULL,
    achternaam VARCHAR(255) NOT NULL,
    geslacht VARCHAR(10) NOT NULL,
    studierichting VARCHAR(255) NOT NULL,
    email VARCHAR(255) NOT NULL,
    telefoon VARCHAR(255),
    woonplaats VARCHAR(255),
    land VARCHAR(255),
    klas VARCHAR(10),
    gemiddelde_cijfer DECIMAL(5,2)
)";
if ($conn->query($table_sql) === FALSE) {
    die("Fout bij aanmaken tabel: " . $conn->error);
}

// Zorg dat de kolom 'klas' bestaat (voor bestaande tabellen)
$klasColumn = $conn->query("SHOW COLUMNS FROM student LIKE 'klas'");
if ($klasColumn && $klasColumn->num_rows === 0) {
    $conn->query("ALTER TABLE student ADD COLUMN klas VARCHAR(10)");
}

// Functie om student toe te voegen of te bewerken
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $id = isset($_POST['id']) ? intval($_POST['id']) : 0;
    $voornaam = $_POST['voornaam'];
    $achternaam = $_POST['achternaam'];
    $geslacht = $_POST['geslacht'];
    $studierichting = $_POST['studierichting'];
    $email = $_POST['email'];
    $telefoon = $_POST['telefoon'];
    $woonplaats = $_POST['woonplaats'];
    $land = $_POST['land'];
    $klas = $_POST['klas'] ?? '';
    $gemiddelde_cijfer = $_POST['gemiddelde_cijfer'];

    if (isset($_POST['opslaan'])) {
        if ($id > 0) {
            // Update student
            $stmt = $conn->prepare("UPDATE student SET voornaam=?, achternaam=?, geslacht=?, studierichting=?, email=?, telefoon=?, woonplaats=?, land=?, klas=?, gemiddelde_cijfer=? WHERE id=?");
            $stmt->bind_param("ssssssssdsi", $voornaam, $achternaam, $geslacht, $studierichting, $email, $telefoon, $woonplaats, $land, $klas, $gemiddelde_cijfer, $id);
            $stmt->execute();
            $stmt->close();
        } else {
            // Voeg toe
            $stmt = $conn->prepare("INSERT INTO student (voornaam, achternaam, geslacht, studierichting, email, telefoon, woonplaats, land, klas, gemiddelde_cijfer) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)");
            $stmt->bind_param("sssssssssd", $voornaam, $achternaam, $geslacht, $studierichting, $email, $telefoon, $woonplaats, $land, $klas, $gemiddelde_cijfer);
            $stmt->execute();
            $stmt->close();
        }
        header("Location: students.php");
        exit;
    } elseif (isset($_POST['discard'])) {
        header("Location: students.php");
        exit;
    }
}

// Verwijder student
if (isset($_GET['delete'])) {
    $id = intval($_GET['delete']);
    $conn->query("DELETE FROM student WHERE id=$id");
    header("Location: students.php");
    exit;
}

// Haal student info op voor bewerken
$student = [
    'id' => '',
    'voornaam' => '',
    'achternaam' => '',
    'geslacht' => '',
    'studierichting' => '',
    'email' => '',
    'telefoon' => '',
    'woonplaats' => '',
    'land' => '',
    'klas' => '',
    'gemiddelde_cijfer' => ''
];
if (isset($_GET['edit'])) {
    $id = intval($_GET['edit']);
    $result = $conn->query("SELECT * FROM student WHERE id=$id");
    if ($result && $result->num_rows > 0) {
        $student = $result->fetch_assoc();
    }
}
